{% for name in proxmox_mcp_service_required_env_names %}
{{ name }}={{ lookup('ansible.builtin.env', name) }}
{% endfor %}
{% for name in proxmox_mcp_service_optional_env_names %}
{{ name }}={{ lookup('ansible.builtin.env', name) }}
{% endfor %}
PVE_SSH_PUBLIC_KEY_FILE={{ proxmox_mcp_service_config_path }}/proxmox-mcp.pub
DATABASE_URL=sqlite:/var/lib/proxmox-mcp/broker.sqlite
AUDIT_LOG_PATH=/var/lib/proxmox-mcp/audit.jsonl
ALLOW_PVE_WRITE=false
ENABLE_DEV_APPROVAL_HTTP=false
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT={{ proxmox_mcp_service_listen_port }}
